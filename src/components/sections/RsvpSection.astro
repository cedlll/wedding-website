---
import config from "../../lib/wedding-config";
---

<section id="rsvp" class="py-24 md:py-32 px-6 md:px-12 lg:px-16" style="background-color: var(--cream);">
  <div class="max-w-7xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-20 md:mb-24">
      <p class="label-text mb-4" style="color: var(--gold-text);">Join us</p>
      <h2
        class="font-display text-5xl md:text-6xl"
        style="color: var(--charcoal); letter-spacing: 0.02em; font-weight: 400;"
      >
        RSVP
      </h2>
      <div class="divider-line mt-8"></div>
      <p class="mt-10 text-base font-body" style="color: var(--text-muted); line-height: 1.7;">
        Please confirm your attendance before <span style="color: var(--charcoal); font-weight: 500;">{config.date.rsvpDeadline}</span>.
      </p>
    </div>

    <!-- Tally popup trigger -->
    <div class="text-center">
      <button
        data-tally-open="dWzjaA"
        data-tally-layout="modal"
        data-tally-overlay="1"
        data-tally-width="700"
        data-tally-emoji-text="💍"
        data-tally-emoji-animation="wave"
        class="inline-block px-12 py-4 text-xs font-semibold tracking-wider uppercase transition-all duration-300 hover:opacity-80"
        style="background-color: var(--charcoal); color: var(--white); border: 2px solid var(--charcoal); letter-spacing: 0.15em; cursor: pointer;"
      >
        Save your seat
      </button>
    </div>
  </div>
</section>
