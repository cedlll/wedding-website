---
import EventFlow from "../islands/EventFlow";
---

<section id="the-day" class="py-24 md:py-32 px-6" style="background-color: var(--white);">
  <div class="max-w-4xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-20 md:mb-24">
      <p class="label-text mb-4" style="color: var(--gold);">The Schedule</p>
      <h2
        class="font-display text-5xl md:text-6xl"
        style="color: var(--charcoal); letter-spacing: 0.02em; font-weight: 400;"
      >
        Order of Events
      </h2>
      <div class="divider-line mt-8"></div>
    </div>

    <EventFlow client:visible />
  </div>
</section>
