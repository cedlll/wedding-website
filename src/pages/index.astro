---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/sections/Hero.astro";
import OurStory from "../components/sections/OurStory.astro";
import EventFlowSection from "../components/sections/EventFlowSection.astro";
import AttireSection from "../components/sections/AttireSection.astro";
import PortfolioGallery from "../components/sections/PortfolioGallery.astro";
import ExperienceSection from "../components/sections/ExperienceSection.astro";
import FaqSection from "../components/sections/FaqSection.astro";
import RsvpSection from "../components/sections/RsvpSection.astro";
import GiftSection from "../components/sections/GiftSection.astro";
import Footer from "../components/sections/Footer.astro";

import StickyNav from "../components/islands/StickyNav";
import MarqueeBand from "../components/islands/MarqueeBand";
---

<Layout>
  <StickyNav client:load />

  <main>
    <Hero />

    <!-- Marquee after hero -->
    <MarqueeBand client:load />

    <OurStory />

    <!-- Dark marquee between story and event flow -->
    <MarqueeBand client:visible dark={true} reverse={true} />

    <EventFlowSection />

    <AttireSection />

    <PortfolioGallery />

    <MarqueeBand client:visible size="sm" />

    <ExperienceSection />

    <RsvpSection />

    <GiftSection />

    <FaqSection />
  </main>

  <Footer />
</Layout>
