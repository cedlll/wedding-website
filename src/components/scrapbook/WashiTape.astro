---
interface Props {
  class?: string;
  variant?: "sage" | "terracotta" | "linen";
  rotation?: number;
}
const { class: className = "", variant = "sage", rotation = -3 } = Astro.props;

const colors = {
  sage: { bg: "rgba(122,139,106,0.35)", stripe: "rgba(122,139,106,0.15)" },
  terracotta: { bg: "rgba(180,130,100,0.3)", stripe: "rgba(180,130,100,0.12)" },
  linen: { bg: "rgba(200,184,162,0.4)", stripe: "rgba(200,184,162,0.15)" },
};

const c = colors[variant];
---

<div
  class={`absolute w-16 h-6 ${className}`}
  style={`transform: rotate(${rotation}deg);`}
  aria-hidden="true"
>
  <svg viewBox="0 0 64 24" class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
    <rect width="64" height="24" fill={c.bg} rx="1" />
    <line x1="0" y1="6" x2="64" y2="6" stroke={c.stripe} stroke-width="2" />
    <line x1="0" y1="12" x2="64" y2="12" stroke={c.stripe} stroke-width="2" />
    <line x1="0" y1="18" x2="64" y2="18" stroke={c.stripe} stroke-width="2" />
    <!-- Torn edges -->
    <path d="M0 0 L2 1 L0 3 L1 5 L0 7 L2 9 L0 11 L1 13 L0 15 L2 17 L0 19 L1 21 L0 24" stroke="none" fill="rgba(250,247,240,0.3)" />
    <path d="M64 0 L62 2 L64 4 L63 6 L64 8 L62 10 L64 12 L63 14 L64 16 L62 18 L64 20 L63 22 L64 24" stroke="none" fill="rgba(250,247,240,0.3)" />
  </svg>
</div>
