---
import config from "../../lib/wedding-config";
---

<!-- Top padding is trimmed because this section shares the white background of the
     preceding schedule section; its bottom padding already supplies the gap. -->
<section id="accommodations" class="pt-4 pb-24 md:pt-6 md:pb-32 px-6" style="background-color: var(--white);">
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16">
      <p class="label-text mb-3" style="color: var(--gold-text);">Where to stay</p>
      <h2
        class="font-display text-5xl md:text-6xl mb-6"
        style="color: var(--charcoal); letter-spacing: 0.02em; font-weight: 400;"
      >
        Stay a while
      </h2>
      <div class="divider-line mt-6"></div>
      <p class="text-text-muted mt-8 max-w-2xl mx-auto" style="font-size: 15px; line-height: 1.8;">
        We've curated a selection of wonderful places to stay near the venue. Book early to secure your preferred choice.
      </p>
    </div>

    <!-- Accommodations Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-10">
      {config.accommodations.map((accommodation) => (
        <article class="stay-card reveal-on-scroll">
          <div class="stay-card__media">
            <img
              src={accommodation.image}
              alt={accommodation.name}
              loading="lazy"
            />
            <span class="stay-card__badge">{accommodation.highlight}</span>
          </div>

          <div class="stay-card__body">
            <h3 class="stay-card__name font-display">
              {accommodation.name}
            </h3>

            <span class="stay-card__rule"></span>

            <p class="stay-card__desc">
              {accommodation.description}
            </p>

            <div class="stay-card__actions">
              {accommodation.website && (
                <a
                  href={accommodation.website}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="stay-card__btn"
                >
                  Visit Website
                </a>
              )}
              {accommodation.phone && (
                <a
                  href={`tel:${accommodation.phone.replace(/\s/g, '')}`}
                  class="stay-card__call"
                >
                  Call →
                </a>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .stay-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background-color: var(--cream);
    border: 1px solid var(--divider);
    border-radius: 3px;
    overflow: hidden;
    transition: transform 0.5s ease, box-shadow 0.5s ease, border-color 0.5s ease;
  }

  .stay-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.1);
    border-color: var(--gold);
  }

  /* ── Media ── */
  .stay-card__media {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .stay-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }

  .stay-card:hover .stay-card__media img {
    transform: scale(1.06);
  }

  /* Soft scrim so the overlaid type reads on lighter photos */
  .stay-card__media::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(26, 26, 24, 0.28) 0%,
      rgba(26, 26, 24, 0) 42%
    );
    pointer-events: none;
  }

  .stay-card__badge {
    position: absolute;
    left: 16px;
    bottom: 16px;
    z-index: 1;
    background-color: var(--cream);
    color: var(--gold-text);
    font-family: "Montserrat", sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 7px 15px;
    border-radius: 999px;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.16);
  }

  /* ── Body ── */
  .stay-card__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 28px 28px 32px;
  }

  .stay-card__name {
    color: var(--charcoal);
    font-size: 1.5rem;
    line-height: 1.25;
    letter-spacing: 0.01em;
  }

  .stay-card__rule {
    display: block;
    width: 38px;
    height: 1px;
    margin: 14px 0 16px;
    background-color: var(--gold);
    opacity: 0.55;
    transition: width 0.5s ease;
  }

  .stay-card:hover .stay-card__rule {
    width: 64px;
  }

  .stay-card__desc {
    color: var(--text-muted);
    font-size: 14px;
    line-height: 1.75;
    /* Push the actions to the bottom so cards align regardless of copy length */
    margin-bottom: 28px;
  }

  .stay-card__actions {
    display: flex;
    align-items: center;
    gap: 22px;
    margin-top: auto;
  }

  .stay-card__btn {
    display: inline-block;
    font-family: "Montserrat", sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--charcoal);
    padding: 11px 22px;
    border: 1px solid var(--gold);
    border-radius: 999px;
    background-color: transparent;
    transition: background-color 0.4s ease, color 0.4s ease;
  }

  .stay-card__btn:hover {
    background-color: var(--gold);
    color: var(--white);
  }

  .stay-card__call {
    font-family: "Montserrat", sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    border-bottom: 1px solid transparent;
    padding-bottom: 2px;
    transition: color 0.4s ease, border-color 0.4s ease;
  }

  .stay-card__call:hover {
    color: var(--charcoal);
    border-color: var(--gold);
  }
</style>
