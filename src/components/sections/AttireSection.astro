---
import AttireSectionIsland from "../islands/AttireSection";
import config from "../../lib/wedding-config";
---

<section id="attire" class="py-16 md:py-24" style="background-color: var(--cream-light);">
  <div>
    <!-- Section header -->
    <div class="text-center mb-10 md:mb-14 px-6">
      <p class="label-text mb-3">Dress code</p>
      <h2
        class="font-display text-section"
        style="color: var(--charcoal);"
      >
        Come dressed
      </h2>
      <div class="divider-line mt-6"></div>
    </div>

    <div class="px-0 md:px-0">
      <AttireSectionIsland client:visible />
    </div>
  </div>
</section>
