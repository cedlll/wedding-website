---
const principalSponsors = [
  "Mrs. Susan Dizon & Mr. Daniel Victolero",
  "Mrs. Brenda Lamsis & Mr. Nick Lamsis",
  "Mrs. Mildred Magno & Mr. Bobby Magno",
  "Mrs. Grail Mcdonald & Mr. Derick Arciso",
  "Mrs. Laurie Lee & Mr. Joseph Lee",
  "Mrs. Michellene Que & Mr. Rudolf Arthur Lee",
];

const secondarySponsors = [
  "Cord: Ms. France De Guzman & Mr. Jedrick Victolero",
  "Candle: Ms. Corina Dizon & Mr. Dan Victolero",
  "Veil: Ms. Donabel Buenconsejo & Capt. Cris Buenconsejo",
];

const brideSide = {
  parentsLabel: "The Parents of the Bride",
  parents: "Jesse P. Victolero & Jocelyn A. Victolero",
  honor: { label: "Maid of Honor", name: "Ms. Ma. Grace Nicole Ortega" },
  matron: { label: "Matron of Honor", name: "Mrs. Nhems Regular-Baang" },
  partyLabel: "Bridesmaids",
  party: ["Camille Leong", "Ashley Lumbang", "Cleo Echano", "Kim Sialongo", "Vianca Kaabay", "Kit Ilagan"],
  childLabel: "Flower Girl",
  child: "Kannelite Suzzane Lee",
};

const groomSide = {
  parentsLabel: "The Parents of the Groom",
  parents: "John Paul S. Lee & Susan L. Lee",
  honor: { label: "Best Man", name: "Mr. Keith Abraham Lee" },
  partyLabel: "Groomsmen",
  party: ["Enrico Herrera", "Kiel Cordon", "Prince Camon", "Timothy James Ortigas", "Abdul Magundacan", "Robin Bunagan"],
  childLabel: "Ring Bearer",
  child: "Cadmus Buenconsejo",
};
---

<section id="entourage" class="py-24 md:py-32 px-6 md:px-12 lg:px-16" style="background-color: var(--cream);">
  <div class="max-w-4xl mx-auto">

    <!-- Section header -->
    <div class="text-center mb-16 md:mb-20">
      <p class="label-text mb-4" style="color: var(--gold-text);">With heartfelt gratitude</p>
      <h2
        class="font-display text-5xl md:text-6xl"
        style="color: var(--charcoal); letter-spacing: 0.02em; font-weight: 400;"
      >
        Entourage
      </h2>
      <div class="divider-line mt-8"></div>
    </div>

    <!-- Sponsors — centered, top -->
    <div class="text-center mb-14 md:mb-16 space-y-8">

      <div>
        <p class="label-text mb-2" style="color: var(--gold-text);">Principal Sponsors</p>
        {principalSponsors.map((pair) => (
          <p class="font-display text-lg md:text-xl" style="color: var(--charcoal); font-weight: 400; line-height: 1.7;">
            {pair}
          </p>
        ))}
      </div>

      <div>
        <p class="label-text mb-2" style="color: var(--gold-text);">Secondary Sponsors</p>
        {secondarySponsors.map((pair) => (
          <p class="font-display text-lg md:text-xl" style="color: var(--charcoal); font-weight: 400; line-height: 1.7;">
            {pair}
          </p>
        ))}
      </div>

    </div>

    <!-- Thin gold rule separating top from columns -->
    <div class="divider-line mb-14 md:mb-16"></div>

    <!-- Two-column split -->
    <div class="relative grid grid-cols-1 md:grid-cols-2 gap-14 md:gap-0">

      <!-- Vertical divider (desktop only) -->
      <div
        class="hidden md:block absolute inset-y-0 left-1/2 -translate-x-1/2"
        style="width: 1px; background: linear-gradient(to bottom, transparent 0%, var(--gold) 8%, var(--gold) 92%, transparent 100%); opacity: 0.35;"
      ></div>

      <!-- Bride's side -->
      <div class="text-center md:pr-14 space-y-8">

        <div>
          <p class="label-text mb-2" style="color: var(--gold-text);">{brideSide.parentsLabel}</p>
          <p class="font-display text-base md:text-lg" style="color: var(--charcoal); font-weight: 400;">
            {brideSide.parents}
          </p>
        </div>

        <div>
          <p class="label-text mb-2" style="color: var(--gold-text);">{brideSide.honor.label}</p>
          <p class="font-display text-base md:text-lg" style="color: var(--charcoal); font-weight: 400;">
            {brideSide.honor.name}
          </p>
        </div>

        <div>
          <p class="label-text mb-2" style="color: var(--gold-text);">{brideSide.matron.label}</p>
          <p class="font-display text-base md:text-lg" style="color: var(--charcoal); font-weight: 400;">
            {brideSide.matron.name}
          </p>
        </div>

        <div>
          <p class="label-text mb-2" style="color: var(--gold-text);">{brideSide.partyLabel}</p>
          {brideSide.party.map((name) => (
            <p class="font-display text-base md:text-lg" style="color: var(--charcoal); font-weight: 400; line-height: 1.7;">
              {name}
            </p>
          ))}
        </div>

        <div>
          <p class="label-text mb-2" style="color: var(--gold-text);">{brideSide.childLabel}</p>
          <p class="font-display text-base md:text-lg" style="color: var(--charcoal); font-weight: 400;">
            {brideSide.child}
          </p>
        </div>

      </div>

      <!-- Groom's side -->
      <div class="text-center md:pl-14 space-y-8">

        <div>
          <p class="label-text mb-2" style="color: var(--gold-text);">{groomSide.parentsLabel}</p>
          <p class="font-display text-base md:text-lg" style="color: var(--charcoal); font-weight: 400;">
            {groomSide.parents}
          </p>
        </div>

        <div>
          <p class="label-text mb-2" style="color: var(--gold-text);">{groomSide.honor.label}</p>
          <p class="font-display text-base md:text-lg" style="color: var(--charcoal); font-weight: 400;">
            {groomSide.honor.name}
          </p>
        </div>

        <div>
          <p class="label-text mb-2" style="color: var(--gold-text);">{groomSide.partyLabel}</p>
          {groomSide.party.map((name) => (
            <p class="font-display text-base md:text-lg" style="color: var(--charcoal); font-weight: 400; line-height: 1.7;">
              {name}
            </p>
          ))}
        </div>

        <div>
          <p class="label-text mb-2" style="color: var(--gold-text);">{groomSide.childLabel}</p>
          <p class="font-display text-base md:text-lg" style="color: var(--charcoal); font-weight: 400;">
            {groomSide.child}
          </p>
        </div>

      </div>
    </div>

  </div>
</section>
