---
import config from "../../lib/wedding-config";

const featuredItems = config.gallery.photos.slice(0, 4);
const allPhotos = config.gallery.photos;

const tilts = ["scrapbook-tilt-2", "scrapbook-tilt-4", "scrapbook-tilt-1", "scrapbook-tilt-6"];
const tapeVariants = ["washi-tape--top-left", "washi-tape--top-right", "washi-tape--top-left washi-tape--cream", "washi-tape--top-right"];
const captions = ["forever starts here", "us, always", "love & laughter", "our favorite place"];
---

<section id="gallery" class="py-24 md:py-32 px-6 paper-texture" style="background-color: var(--cream);">
  <div class="max-w-6xl mx-auto">
    <!-- Section header with handwriting accent -->
    <div class="text-center mb-20">
      <p class="font-handwriting text-2xl md:text-3xl mb-2" style="color: var(--gold); transform: rotate(-1deg);">
        our favorite moments
      </p>
      <h2
        class="font-display text-5xl md:text-6xl mb-6"
        style="color: var(--charcoal); letter-spacing: 0.02em; font-weight: 400;"
      >
        A Few Memories
      </h2>
      <div class="divider-line mt-6"></div>
    </div>

    <!-- Scrapbook Grid (featured 4) -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 max-w-4xl mx-auto">
      {featuredItems.map((photo, i) => (
        <div class={`relative scrapbook-photo ${tilts[i]} group cursor-pointer`}>
          {/* Washi tape */}
          <div class={`washi-tape ${tapeVariants[i]}`} />

          <div class="aspect-[4/3] overflow-hidden">
            <img
              src={photo.src}
              alt={photo.alt}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
          </div>

          {/* Handwritten caption */}
          <p class="scrapbook-caption text-center mt-2">
            {captions[i]}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
