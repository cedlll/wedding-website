---
interface Props {
  class?: string;
  color?: string;
}
const { class: className = "", color = "var(--olive)" } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 60 140"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <path
    d="M30 130 C30 110, 28 80, 30 20"
    stroke={color}
    stroke-width="1.25"
    stroke-linecap="round"
  />
  <ellipse cx="22" cy="110" rx="8" ry="12" transform="rotate(-15 22 110)" stroke={color} stroke-width="1.25" />
  <ellipse cx="38" cy="95" rx="8" ry="12" transform="rotate(12 38 95)" stroke={color} stroke-width="1.25" />
  <ellipse cx="20" cy="78" rx="7" ry="11" transform="rotate(-10 20 78)" stroke={color} stroke-width="1.25" />
  <ellipse cx="40" cy="62" rx="7" ry="11" transform="rotate(8 40 62)" stroke={color} stroke-width="1.25" />
  <ellipse cx="22" cy="48" rx="6" ry="9" transform="rotate(-12 22 48)" stroke={color} stroke-width="1.25" />
  <ellipse cx="38" cy="34" rx="6" ry="9" transform="rotate(10 38 34)" stroke={color} stroke-width="1.25" />
  <ellipse cx="28" cy="22" rx="4" ry="7" transform="rotate(-5 28 22)" stroke={color} stroke-width="1.25" />
</svg>
