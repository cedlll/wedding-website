---
import GiftRegistry from "../islands/GiftRegistry";
---

<!-- Top padding is trimmed because this section shares the cream background of the
     preceding RSVP section; that section's bottom padding supplies the gap. -->
<section id="gifts" class="pt-4 pb-24 md:pt-6 md:pb-32 px-6 md:px-12 lg:px-16" style="background-color: var(--cream);">
  <div class="max-w-7xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16 md:mb-20">
      <p class="label-text mb-4">Generosity</p>
      <h2
        class="font-display text-section"
        style="color: var(--charcoal);"
      >
        Gifts
      </h2>
      <div class="divider-line mt-6"></div>
    </div>

    <GiftRegistry client:visible />
  </div>
</section>
