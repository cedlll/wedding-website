---
// 3-column highlights section inspired by Lovio's service cards
---

<section id="highlights" class="py-24 md:py-32 px-6" style="background-color: var(--white);">
  <div class="max-w-7xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-20">
      <h2
        class="font-display text-5xl md:text-6xl mb-6"
        style="color: var(--charcoal); letter-spacing: 0.02em; font-weight: 400;"
      >
        A Celebration of Love
      </h2>
      <div class="divider-line mt-6"></div>
    </div>

    <!-- 3-column cards grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10">
      <!-- Card 1: The Ceremony -->
      <div class="group">
        <div class="aspect-[4/5] overflow-hidden mb-6">
          <img
            src="https://images.unsplash.com/photo-1519741497674-611481863552?w=600&h=750&fit=crop"
            alt="The Ceremony"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
        </div>
        <h3
          class="font-display text-2xl mb-4 transition-colors duration-300 group-hover:text-gold"
          style="color: var(--charcoal); letter-spacing: 0.02em; font-weight: 400;"
        >
          The Ceremony
        </h3>
        <p class="text-base leading-relaxed font-body mb-6" style="color: var(--text-muted); line-height: 1.7;">
          Join us as we exchange vows in an intimate garden setting, surrounded by love, laughter, and the beauty of nature.
        </p>
        <a
          href="#the-day"
          class="text-xs font-semibold tracking-wider uppercase transition-colors duration-300"
          style="color: var(--gold); letter-spacing: 0.12em;"
        >
          Learn More →
        </a>
      </div>

      <!-- Card 2: The Reception -->
      <div class="group">
        <div class="aspect-[4/5] overflow-hidden mb-6">
          <img
            src="https://images.unsplash.com/photo-1464366400600-7168b8af9bc3?w=600&h=750&fit=crop"
            alt="The Reception"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
        </div>
        <h3
          class="font-display text-2xl mb-4 transition-colors duration-300 group-hover:text-gold"
          style="color: var(--charcoal); letter-spacing: 0.02em; font-weight: 400;"
        >
          The Reception
        </h3>
        <p class="text-base leading-relaxed font-body mb-6" style="color: var(--text-muted); line-height: 1.7;">
          An evening of celebration with delicious cuisine, heartfelt toasts, and dancing under the stars.
        </p>
        <a
          href="#the-day"
          class="text-xs font-semibold tracking-wider uppercase transition-colors duration-300"
          style="color: var(--gold); letter-spacing: 0.12em;"
        >
          Learn More →
        </a>
      </div>

      <!-- Card 3: The Experience -->
      <div class="group">
        <div class="aspect-[4/5] overflow-hidden mb-6">
          <img
            src="https://images.unsplash.com/photo-1551882547-ff40c63fe5fa?w=600&h=750&fit=crop"
            alt="The Experience"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
        </div>
        <h3
          class="font-display text-2xl mb-4 transition-colors duration-300 group-hover:text-gold"
          style="color: var(--charcoal); letter-spacing: 0.02em; font-weight: 400;"
        >
          The Experience
        </h3>
        <p class="text-base leading-relaxed font-body mb-6" style="color: var(--text-muted); line-height: 1.7;">
          Make it a weekend getaway in beautiful Tagaytay with breathtaking views and unforgettable memories.
        </p>
        <a
          href="#experience"
          class="text-xs font-semibold tracking-wider uppercase transition-colors duration-300"
          style="color: var(--gold); letter-spacing: 0.12em;"
        >
          Learn More →
        </a>
      </div>
    </div>
  </div>
</section>
