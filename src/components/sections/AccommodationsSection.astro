---
import config from "../../lib/wedding-config";
---

<section id="accommodations" class="py-24 md:py-32 px-6" style="background-color: var(--white);">
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16">
      <p class="label-text mb-3" style="color: var(--gold-text);">Where to stay</p>
      <h2
        class="font-display text-5xl md:text-6xl mb-6"
        style="color: var(--charcoal); letter-spacing: 0.02em; font-weight: 400;"
      >
        Stay a while
      </h2>
      <div class="divider-line mt-6"></div>
      <p class="text-text-muted mt-8 max-w-2xl mx-auto" style="font-size: 15px; line-height: 1.8;">
        We've curated a selection of wonderful places to stay near the venue. Book early to secure your preferred choice.
      </p>
    </div>

    <!-- Accommodations Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-10">
      {config.accommodations.map((accommodation) => (
        <div class="card-hover bg-cream rounded-sm overflow-hidden reveal-on-scroll">
          <div class="card-image-hover aspect-[3/2] overflow-hidden">
            <img
              src={accommodation.image}
              alt={accommodation.name}
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>

          <div class="p-6 md:p-8">
            <h3 class="font-display text-2xl mb-3" style="color: var(--charcoal); letter-spacing: 0.01em;">
              {accommodation.name}
            </h3>

            <p class="label-text mb-4" style="color: var(--gold-text);">
              {accommodation.distance}
            </p>

            <p class="text-text-muted mb-6" style="font-size: 14px; line-height: 1.7;">
              {accommodation.description}
            </p>

            {accommodation.website && (
              <a
                href={accommodation.website}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-block text-sm font-medium uppercase tracking-wider transition-colors"
                style="color: var(--charcoal); letter-spacing: 0.1em; border-bottom: 1px solid var(--gold);"
              >
                View website →
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
