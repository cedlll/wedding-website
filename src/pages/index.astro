---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/sections/Hero.astro";
import HighlightsSection from "../components/sections/HighlightsSection.astro";
import PortfolioGallery from "../components/sections/PortfolioGallery.astro";
import EventFlowSection from "../components/sections/EventFlowSection.astro";
import AttireSection from "../components/sections/AttireSection.astro";
import EntourageSection from "../components/sections/EntourageSection.astro";
import AccommodationsSection from "../components/sections/AccommodationsSection.astro";
import FaqSection from "../components/sections/FaqSection.astro";
import RsvpSection from "../components/sections/RsvpSection.astro";
import GiftSection from "../components/sections/GiftSection.astro";
import Footer from "../components/sections/Footer.astro";

import StickyNav from "../components/islands/StickyNav";
---

<Layout>
  <StickyNav client:load />

  <main id="main-content">
    <!-- Hero Carousel (like Lovio) -->
    <Hero />

    <!-- Venue Section -->
    <HighlightsSection />

    <!-- Attire Details -->
    <AttireSection />

    <!-- Entourage -->
    <EntourageSection />

    <!-- Photo Gallery -->
    <PortfolioGallery />

    <!-- Event Flow Schedule -->
    <EventFlowSection />

    <!-- Nearby Accommodations -->
    <AccommodationsSection />

    <!-- RSVP Form -->
    <RsvpSection />

    <!-- Gift Registry -->
    <GiftSection />

    <!-- FAQ Accordion -->
    <FaqSection />
  </main>

  <Footer />
</Layout>
