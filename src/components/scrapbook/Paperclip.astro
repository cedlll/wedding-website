---
interface Props {
  class?: string;
  color?: string;
}
const { class: className = "", color = "var(--wood)" } = Astro.props;
---

<svg
  class={`absolute ${className}`}
  viewBox="0 0 20 50"
  width="20"
  height="50"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <path
    d="M6 2 C6 2, 2 2, 2 8 L2 38 C2 44, 8 48, 14 48 C20 48, 18 44, 18 38 L18 12 C18 8, 14 6, 10 6 C6 6, 6 10, 6 12 L6 36"
    stroke={color}
    stroke-width="1.25"
    stroke-linecap="round"
    opacity="0.5"
  />
</svg>
