---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 120 80"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <!-- Envelope body -->
  <rect x="4" y="20" width="112" height="56" rx="2" stroke="var(--wood)" stroke-width="1.25" />
  <!-- Flap -->
  <path d="M4 20 L60 52 L116 20" stroke="var(--wood)" stroke-width="1.25" stroke-linejoin="round" />
  <!-- Small olive sprig on flap -->
  <path d="M55 32 C58 28, 62 26, 65 28" stroke="var(--olive-soft)" stroke-width="1" stroke-linecap="round" />
  <path d="M58 30 C56 27, 58 24, 60 26" stroke="var(--olive-soft)" stroke-width="1" />
  <path d="M62 28 C64 25, 67 24, 66 27" stroke="var(--olive-soft)" stroke-width="1" />
</svg>
