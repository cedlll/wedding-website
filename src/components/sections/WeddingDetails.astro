---
import OliveBranch from "../icons/OliveBranch.astro";
import LeafDivider from "../icons/LeafDivider.astro";
import EucalyptusSprig from "../icons/EucalyptusSprig.astro";
import config from "../../lib/wedding-config";
---

<section id="details" class="py-24 px-6" style="background-color: var(--paper);">
  <div class="max-w-5xl mx-auto">
    <!-- Section label -->
    <div class="text-center mb-16">
      <span class="section-label">02 · The Day</span>
      <h2 class="font-display text-4xl md:text-5xl font-light mt-4" style="color: var(--wood-deep);">
        Wedding Details
      </h2>
      <LeafDivider class="max-w-xs mx-auto mt-6" />
    </div>

    <!-- Ceremony & Reception cards -->
    <div class="grid md:grid-cols-2 gap-8 mb-16">
      <!-- Ceremony -->
      <div class="card-bordered rounded-sm p-8 relative overflow-hidden">
        <!-- Corner ornaments -->
        <OliveBranch class="absolute top-2 left-2 w-16 h-8 opacity-20" />
        <OliveBranch class="absolute bottom-2 right-2 w-16 h-8 opacity-20 rotate-180" />

        <span class="section-label block mb-4">Ceremony</span>
        <h3 class="font-display text-2xl font-normal mb-2" style="color: var(--wood-deep);">
          {config.venue.name}
        </h3>
        <p class="font-body italic mb-3" style="color: var(--olive-soft);">
          {config.venue.ceremonyRoom}
        </p>
        <p class="font-script text-3xl mb-4" style="color: var(--gold);">
          {config.date.ceremony}
        </p>
        <p class="font-body text-sm mb-4" style="color: var(--wood-deep); opacity: 0.85;">
          {config.venue.fullAddress}
        </p>
        <a
          href={config.venue.googleMapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono-micro inline-flex items-center gap-1 transition-colors"
          style="color: var(--olive); border-bottom: 1px solid var(--olive);"
        >
          Get Directions →
        </a>
      </div>

      <!-- Reception -->
      <div class="card-bordered rounded-sm p-8 relative overflow-hidden">
        <OliveBranch class="absolute top-2 right-2 w-16 h-8 opacity-20 -scale-x-100" />
        <OliveBranch class="absolute bottom-2 left-2 w-16 h-8 opacity-20 -scale-x-100 rotate-180" />

        <span class="section-label block mb-4">Reception</span>
        <h3 class="font-display text-2xl font-normal mb-2" style="color: var(--wood-deep);">
          {config.venue.name}
        </h3>
        <p class="font-body italic mb-3" style="color: var(--olive-soft);">
          {config.venue.receptionRoom}
        </p>
        <p class="font-script text-3xl mb-4" style="color: var(--gold);">
          {config.date.reception}
        </p>
        <p class="font-body text-sm mb-4" style="color: var(--wood-deep); opacity: 0.85;">
          {config.venue.fullAddress}
        </p>
        <a
          href={config.venue.googleMapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono-micro inline-flex items-center gap-1 transition-colors"
          style="color: var(--olive); border-bottom: 1px solid var(--olive);"
        >
          Get Directions →
        </a>
      </div>
    </div>

    <!-- Stylized venue map -->
    <div class="mb-16 flex justify-center">
      <svg
        viewBox="0 0 600 200"
        class="w-full max-w-2xl"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-label="Stylized map of Tagaytay with Hacienda Solange marked"
        role="img"
      >
        <!-- Taal Lake outline -->
        <path
          d="M180 160 C200 130, 260 100, 320 110 C380 120, 420 140, 440 160 C420 175, 360 185, 300 180 C240 175, 200 170, 180 160Z"
          stroke="var(--wood)"
          stroke-width="1.25"
          opacity="0.3"
        />
        <text x="310" y="150" text-anchor="middle" font-family="'JetBrains Mono', monospace" font-size="8" letter-spacing="0.2em" fill="var(--wood)" opacity="0.25">TAAL LAKE</text>

        <!-- Taal Volcano island -->
        <ellipse cx="310" cy="145" rx="25" ry="15" stroke="var(--wood)" stroke-width="1" opacity="0.2" />

        <!-- Tagaytay ridge road -->
        <path
          d="M80 90 C150 80, 250 70, 350 75 C450 80, 520 85, 560 90"
          stroke="var(--wood)"
          stroke-width="1"
          stroke-dasharray="6 4"
          opacity="0.3"
        />
        <text x="480" y="85" font-family="'JetBrains Mono', monospace" font-size="6" letter-spacing="0.15em" fill="var(--wood)" opacity="0.3">TAGAYTAY RIDGE</text>

        <!-- Pin for Hacienda Solange -->
        <g transform="translate(280, 55)">
          <path d="M0 20 C0 8, 6 0, 12 0 C18 0, 24 8, 24 20 C24 32, 12 40, 12 40 C12 40, 0 32, 0 20Z" stroke="var(--olive)" stroke-width="1.5" fill="rgba(74,93,58,0.1)" />
          <circle cx="12" cy="18" r="4" stroke="var(--olive)" stroke-width="1" />
        </g>
        <text x="315" y="68" font-family="'Cormorant Garamond', serif" font-size="11" fill="var(--wood-deep)">{config.venue.name}</text>

        <!-- Direction from Manila -->
        <path
          d="M50 50 L80 90"
          stroke="var(--wood)"
          stroke-width="0.75"
          stroke-dasharray="3 3"
          opacity="0.2"
        />
        <text x="20" y="45" font-family="'JetBrains Mono', monospace" font-size="6" letter-spacing="0.15em" fill="var(--wood)" opacity="0.25">FROM MANILA</text>
      </svg>
    </div>

    <!-- Dress code -->
    <div class="card-bordered rounded-sm p-8 max-w-2xl mx-auto text-center">
      <span class="section-label block mb-4">Dress Code</span>
      <h3 class="font-display text-2xl font-normal mb-3" style="color: var(--wood-deep);">
        {config.dresscode.theme}
      </h3>
      <p class="font-body mb-6" style="color: var(--wood-deep); opacity: 0.85;">
        {config.dresscode.description}
      </p>

      <!-- Color palette -->
      <div class="flex justify-center gap-6 mb-6">
        {config.dresscode.palette.map((color, i) => (
          <div class="group flex flex-col items-center gap-2">
            <div
              class="w-12 h-12 rounded-full transition-all duration-200 group-hover:shadow-warm-sm group-hover:-translate-y-1 border"
              style={`background-color: ${color}; border-color: rgba(107,79,58,0.15);`}
            ></div>
            <span
              class="font-mono-micro opacity-0 group-hover:opacity-100 transition-opacity"
              style="font-size: 9px; color: var(--wood);"
            >
              {config.dresscode.paletteLabels[i]}
            </span>
          </div>
        ))}
      </div>

      <p class="font-body italic text-sm" style="color: var(--olive-soft);">
        Please avoid: {config.dresscode.avoid.join(", ")}
      </p>

      <!-- Suit and dress silhouettes -->
      <div class="flex justify-center gap-12 mt-8">
        <!-- Suit silhouette -->
        <svg viewBox="0 0 40 60" class="w-10 h-16" fill="none" aria-hidden="true">
          <path d="M15 5 L12 20 L8 55 L18 55 L20 30 L22 55 L32 55 L28 20 L25 5Z" stroke="var(--wood)" stroke-width="1" opacity="0.3" />
          <path d="M15 5 L20 15 L25 5" stroke="var(--wood)" stroke-width="1" opacity="0.3" />
          <line x1="20" y1="15" x2="20" y2="40" stroke="var(--wood)" stroke-width="0.5" opacity="0.2" />
          <!-- Small sprig -->
          <path d="M24 15 C26 13, 28 11, 29 10" stroke="var(--olive-soft)" stroke-width="0.75" stroke-linecap="round" />
          <path d="M26 12 C27 10, 29 9, 28 11" stroke="var(--olive-soft)" stroke-width="0.75" />
        </svg>

        <!-- Dress silhouette -->
        <svg viewBox="0 0 40 60" class="w-10 h-16" fill="none" aria-hidden="true">
          <path d="M16 5 C14 10, 12 18, 10 25 C6 35, 4 48, 3 55 L37 55 C36 48, 34 35, 30 25 C28 18, 26 10, 24 5Z" stroke="var(--wood)" stroke-width="1" opacity="0.3" />
          <path d="M16 5 Q20 8, 24 5" stroke="var(--wood)" stroke-width="1" opacity="0.3" />
          <!-- Small sprig -->
          <path d="M20 20 C22 17, 24 15, 25 14" stroke="var(--olive-soft)" stroke-width="0.75" stroke-linecap="round" />
          <path d="M22 17 C23 15, 25 14, 24 16" stroke="var(--olive-soft)" stroke-width="0.75" />
        </svg>
      </div>
    </div>
  </div>
</section>
