---
import AttireSectionIsland from "../islands/AttireSection";
import config from "../../lib/wedding-config";
---

<section id="attire" class="py-24 md:py-32 px-6" style="background-color: var(--cream-light);">
  <div class="max-w-5xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16 md:mb-20">
      <p class="label-text mb-4">Dress Code</p>
      <h2
        class="font-display text-section"
        style="color: var(--charcoal);"
      >
        Attire & Palette
      </h2>
      <div class="divider-line mt-6"></div>
    </div>

    <AttireSectionIsland client:visible />
  </div>
</section>
