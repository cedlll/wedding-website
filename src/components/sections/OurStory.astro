---
import StorySection from "../islands/StorySection";
---

<section id="our-story" class="py-24 md:py-32 px-6 md:px-12 lg:px-16 paper-texture" style="background-color: var(--cream);">
  <div class="max-w-7xl mx-auto">
    <!-- Section header with scrapbook annotation -->
    <div class="text-center mb-20 md:mb-24">
      <p class="font-handwriting text-2xl md:text-3xl mb-2" style="color: var(--gold); transform: rotate(-2deg);">
        how it all began...
      </p>
      <h2
        class="font-display text-5xl md:text-6xl"
        style="color: var(--charcoal); letter-spacing: 0.02em; font-weight: 400;"
      >
        How we got here
      </h2>
      <div class="divider-line mt-8"></div>
    </div>

    <StorySection client:visible />
  </div>
</section>
