---
import config from "../../lib/wedding-config";

const featuredItems = config.gallery.photos.slice(0, 4);
const allPhotos = config.gallery.photos;

const tilts = ["scrapbook-tilt-2", "scrapbook-tilt-4", "scrapbook-tilt-1", "scrapbook-tilt-6"];
const tapeVariants = ["washi-tape--top-left", "washi-tape--top-right", "washi-tape--top-left washi-tape--cream", "washi-tape--top-right"];
const captions = ["First photo", "First international travel", "First beach trip", "First date as a couple"];
const years = ["2014", "2025", "2022", "2022"];
const venues = ["LPU", "Vietnam", "Zambales", "Blackbird Makati"];
---

<!-- Top padding is trimmed because this section shares the cream background of the
     preceding entourage section; that section's bottom padding supplies the gap. -->
<section id="gallery" class="pt-4 pb-24 md:pt-6 md:pb-32 px-6 paper-texture" style="background-color: var(--cream);">
  <div class="max-w-6xl mx-auto">
    <!-- Section header with handwriting accent -->
    <div class="text-center mb-20">
      <p class="font-handwriting text-2xl md:text-3xl mb-2" style="color: var(--gold); transform: rotate(-1deg);">
        about us
      </p>
      <h2
        class="font-display text-5xl md:text-6xl mb-6"
        style="color: var(--charcoal); letter-spacing: 0.02em; font-weight: 400;"
      >
        Our firsts
      </h2>
      <div class="divider-line mt-6"></div>
    </div>

    <!-- Mobile swipe hint -->
    <p class="md:hidden text-center font-handwriting text-xl -mt-12 mb-8" style="color: var(--text-muted); transform: rotate(-1deg);">
      swipe to flip through <span class="swipe-arrow" aria-hidden="true">→</span>
    </p>

    <!-- Scrapbook Grid: horizontal scroll on mobile, 2-col grid on desktop.
         pt/-mt on mobile gives the washi tape (which sticks out above each
         polaroid) room inside the overflow clip box. -->
    <div class="gallery-scrapbook reveal-on-scroll flex md:grid md:grid-cols-2 gap-6 md:gap-16 max-w-4xl mx-auto overflow-x-auto md:overflow-visible snap-x snap-mandatory pt-6 -mt-6 md:pt-0 md:mt-0 pb-4 md:pb-0 -mx-6 px-6 md:mx-auto md:px-0">
      {featuredItems.map((photo, i) => (
        <div class={`relative scrapbook-photo ${tilts[i]} group flex-shrink-0 w-[70vw] md:w-auto snap-center`}>
          {/* Washi tape */}
          <div class={`washi-tape ${tapeVariants[i]}`} />

          <div class="aspect-[4/3] overflow-hidden">
            <img
              src={photo.src}
              alt={photo.alt}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
          </div>

          {/* Handwritten caption */}
          <p class="scrapbook-caption text-center mt-2">
            {captions[i]}
          </p>
          <p class="scrapbook-year text-center">{venues[i]} · {years[i]}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .scrapbook-year {
    font-family: 'Caveat', cursive;
    font-size: 1rem;
    color: var(--gold);
    transform: rotate(-1deg);
    opacity: 0.9;
    margin-top: 0.1rem;
  }

  .swipe-arrow {
    display: inline-block;
    animation: swipe-nudge 1.6s ease-in-out infinite;
  }

  @keyframes swipe-nudge {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(6px); }
  }
</style>
