---
import ExperienceCards from "../islands/ExperienceCards";
---

<section id="experience" class="py-24 md:py-32 px-6" style="background-color: var(--cream);">
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-20 md:mb-24">
      <p class="label-text mb-4" style="color: var(--gold);">Discover</p>
      <h2
        class="font-display text-5xl md:text-6xl"
        style="color: var(--charcoal); letter-spacing: 0.02em; font-weight: 400;"
      >
        The Alfonso Experience
      </h2>
      <div class="divider-line mt-8"></div>
    </div>

    <ExperienceCards client:visible />
  </div>
</section>
