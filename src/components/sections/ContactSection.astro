---
import OliveBranch from "../icons/OliveBranch.astro";
import LeafDivider from "../icons/LeafDivider.astro";
import config from "../../lib/wedding-config";
---

<section id="contact" class="py-24 px-6">
  <div class="max-w-4xl mx-auto">
    <!-- Section label -->
    <div class="text-center mb-10">
      <span class="section-label">08 · Contact</span>
      <h2 class="font-display text-4xl md:text-5xl font-light mt-4" style="color: var(--wood-deep);">
        Get in Touch
      </h2>
      <LeafDivider class="max-w-xs mx-auto mt-6" />
    </div>

    <p class="font-body italic text-center mb-12" style="color: var(--wood-deep); opacity: 0.85;">
      For anything you need, don't hesitate to reach out.
    </p>

    <!-- Envelope with olive sprig illustration -->
    <div class="flex justify-center mb-12">
      <svg viewBox="0 0 120 80" class="w-24 h-16" fill="none" aria-hidden="true">
        <rect x="4" y="20" width="112" height="56" rx="2" stroke="var(--wood)" stroke-width="1.25" opacity="0.4" />
        <path d="M4 20 L60 52 L116 20" stroke="var(--wood)" stroke-width="1.25" stroke-linejoin="round" opacity="0.4" />
        <path d="M50 28 C55 22, 62 18, 68 20 C72 22, 70 26, 65 24 C60 22, 58 26, 62 28" stroke="var(--olive-soft)" stroke-width="1.25" stroke-linecap="round" />
        <path d="M55 24 C53 20, 56 16, 58 19" stroke="var(--olive-soft)" stroke-width="1" />
        <path d="M62 21 C65 17, 69 16, 67 20" stroke="var(--olive-soft)" stroke-width="1" />
      </svg>
    </div>

    <!-- Contact cards -->
    <div class="grid md:grid-cols-2 gap-8 max-w-2xl mx-auto">
      {config.contacts.map((contact) => (
        <div class="card-bordered rounded-sm p-6 relative overflow-hidden">
          <OliveBranch class="absolute top-1 right-1 w-12 h-6 opacity-15" />

          <h3 class="font-display text-xl font-normal mb-1" style="color: var(--wood-deep);">
            {contact.name}
          </h3>
          <span class="section-label block mb-4">{contact.role}</span>

          <div class="space-y-2">
            <p class="font-body text-sm flex items-center gap-2" style="color: var(--wood-deep);">
              <svg viewBox="0 0 16 16" class="w-4 h-4 flex-shrink-0" fill="none" aria-hidden="true">
                <path d="M3 2h10a1 1 0 011 1v10a1 1 0 01-1 1H3a1 1 0 01-1-1V3a1 1 0 011-1z" stroke="var(--olive-soft)" stroke-width="1" />
                <path d="M5 6l3 3 3-3" stroke="var(--olive-soft)" stroke-width="1" stroke-linecap="round" />
              </svg>
              {contact.phone}
            </p>
            <p class="font-body text-sm flex items-center gap-2" style="color: var(--wood-deep);">
              <svg viewBox="0 0 16 16" class="w-4 h-4 flex-shrink-0" fill="none" aria-hidden="true">
                <rect x="1" y="3" width="14" height="10" rx="1" stroke="var(--olive-soft)" stroke-width="1" />
                <path d="M1 4l7 5 7-5" stroke="var(--olive-soft)" stroke-width="1" />
              </svg>
              {contact.email}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
