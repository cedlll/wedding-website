---
import config from "../../lib/wedding-config";
---

<section id="details" class="py-24 md:py-32 px-6" style="background-color: var(--cream);">
  <div class="max-w-6xl mx-auto">
    <!-- Two column layout: Text + Image -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Text Content -->
      <div>
        <p class="label-text mb-6" style="color: var(--gold);">About Our Day</p>
        <h2
          class="font-display text-4xl md:text-5xl mb-8"
          style="color: var(--charcoal); letter-spacing: 0.02em; font-weight: 400;"
        >
          Join Us in Celebration
        </h2>

        <p
          class="font-body text-lg leading-relaxed mb-8"
          style="color: var(--text-muted); line-height: 1.8;"
        >
          {config.tagline}
        </p>

        <!-- Event Details -->
        <div class="space-y-6">
          <div>
            <p class="label-text mb-2" style="color: var(--gold);">Date</p>
            <p class="font-display text-xl" style="color: var(--charcoal); letter-spacing: 0.02em;">
              {config.date.dayOfWeek}, {config.date.display}
            </p>
          </div>

          <div>
            <p class="label-text mb-2" style="color: var(--gold);">Location</p>
            <p class="font-display text-xl" style="color: var(--charcoal); letter-spacing: 0.02em;">
              {config.venue.name}
            </p>
            <p class="font-body text-sm mt-1" style="color: var(--text-muted);">
              {config.venue.city}, {config.venue.country}
            </p>
          </div>

          <div>
            <p class="label-text mb-2" style="color: var(--gold);">Dress Code</p>
            <p class="font-display text-xl" style="color: var(--charcoal); letter-spacing: 0.02em;">
              {config.attire.theme}
            </p>
          </div>
        </div>
      </div>

      <!-- Right: Image -->
      <div class="aspect-[4/5] overflow-hidden">
        <img
          src="https://images.unsplash.com/photo-1519741497674-611481863552?w=800&h=1000&fit=crop"
          alt="Wedding venue"
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
