---
import GiftEnvelopes from "../islands/GiftEnvelopes";
import LeafDivider from "../icons/LeafDivider.astro";
---

<section id="gifts" class="py-24 px-6">
  <div class="max-w-4xl mx-auto">
    <!-- Section label -->
    <div class="text-center mb-10">
      <span class="section-label">06 · Gifts</span>
      <h2 class="font-display text-4xl md:text-5xl font-light mt-4" style="color: var(--wood-deep);">
        Your Generosity
      </h2>
      <LeafDivider class="max-w-xs mx-auto mt-6" />
    </div>

    <p class="font-body italic text-center max-w-lg mx-auto mb-12" style="color: var(--wood-deep); opacity: 0.85;">
      Your presence at our celebration is the greatest gift we could ask for.
      But if you wish to bless our new home as we begin this chapter...
    </p>

    <GiftEnvelopes client:visible />
  </div>
</section>
