---
import "../styles/global.css";
import config from "../lib/wedding-config";
import Analytics from "@vercel/analytics/astro";

interface Props {
  title?: string;
  canonicalUrl?: string;
}

const { title = `${config.couple.partner1} & ${config.couple.partner2} — ${config.date.display}`, canonicalUrl = new URL(Astro.url.pathname, Astro.site).href } = Astro.props;
const description = `Join ${config.couple.partner1} and ${config.couple.partner2} as they celebrate their wedding on ${config.date.display} at ${config.venue.name}, ${config.venue.city}.`;
const ogImage = new URL("/images/og-image.jpeg", Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#FFFBF5" />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1462" />
    <meta property="og:image:height" content="710" />
    <meta property="og:url" content={canonicalUrl} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Twitter / iMessage -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured data: Event -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Event",
      "name": `${config.couple.partner1} & ${config.couple.partner2} Wedding`,
      "startDate": config.date.iso,
      "location": {
        "@type": "Place",
        "name": config.venue.name,
        "address": config.venue.fullAddress
      },
      "description": description
    })} />

    <!-- First hero slide is the LCP element; fetch it before the React island hydrates -->
    <link rel="preload" as="image" href="/images/hero/hero-01.webp" fetchpriority="high" />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body>
    <!-- Skip navigation for keyboard users -->
    <a
      href="#main-content"
      class="absolute left-4 top-4 -translate-y-20 focus:translate-y-0 z-[200] px-4 py-2 bg-charcoal text-white text-sm font-medium transition-transform duration-200 focus:outline-none focus:ring-2 focus:ring-gold"
      style="background-color: var(--charcoal); color: var(--white);"
    >
      Skip to main content
    </a>
    <slot />
    <Analytics />
    <!-- Scroll-reveal observer for .reveal-on-scroll elements -->
    <script is:inline>
      document.addEventListener("DOMContentLoaded", function () {
        var els = document.querySelectorAll(".reveal-on-scroll");
        if (!els.length) return;
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add("is-visible");
              io.unobserve(e.target);
            }
          });
        }, { threshold: 0.15 });
        els.forEach(function (el) { io.observe(el); });
      });
    </script>
    <!-- Tally embed script for RSVP popup (is:inline bypasses Vite processing; snippet calls loadEmbeds() explicitly after load) -->
    <script is:inline>var d=document,w="https://tally.so/widgets/embed.js",v=function(){"undefined"!=typeof Tally?Tally.loadEmbeds():d.querySelectorAll("[data-tally-src]:not([data-tally-loaded])").forEach((function(e){e.dataset.tallyLoaded=1;var t=d.createElement("iframe");t.setAttribute("src",e.dataset.tallySrc),t.setAttribute("width","100%");var n=e.dataset.tallyHeight,r=e.dataset.tallyPage;n&&t.setAttribute("height",n),r&&t.setAttribute("height","auto"),e.parentNode.insertBefore(t,e),e.remove()}))};if("undefined"!=typeof Tally)v();else if(d.querySelector('script[src="'+w+'"]')==null){var s=d.createElement("script");s.src=w,s.onload=v,s.onerror=v,d.body.appendChild(s)}</script>
  </body>
</html>
