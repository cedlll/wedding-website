---
import TestimonialsCarousel from "../islands/TestimonialsCarousel";
---

<section id="testimonials" class="py-24 md:py-32 px-6" style="background-color: var(--cream);">
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16">
      <p class="label-text mb-4" style="color: var(--gold-text);">Kind words</p>
      <h2
        class="font-display text-5xl md:text-6xl"
        style="color: var(--charcoal); letter-spacing: 0.02em; font-weight: 400;"
      >
        From the people who know us
      </h2>
      <div class="divider-line mt-8"></div>
    </div>

    <TestimonialsCarousel client:visible />
  </div>
</section>
