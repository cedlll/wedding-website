---
import FaqAccordion from "../islands/FaqAccordion";
---

<section id="faq" class="py-24 md:py-32 px-6 md:px-12 lg:px-16" style="background-color: var(--white);">
  <div class="max-w-7xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-20 md:mb-24">
      <p class="label-text mb-4" style="color: var(--gold-text);">Information</p>
      <h2
        class="font-display text-5xl md:text-6xl"
        style="color: var(--charcoal); letter-spacing: 0.02em; font-weight: 400;"
      >
        FAQs
      </h2>
      <div class="divider-line mt-8"></div>
    </div>

    <FaqAccordion client:visible />

    <p class="text-center mt-16 text-sm font-body" style="color: var(--text-muted); line-height: 1.7;">
      Have other questions? Reach us at <a href="mailto:cedricandkaren2026@gmail.com" class="font-medium underline underline-offset-2" style="color: var(--charcoal);">cedricandkaren2026@gmail.com</a>
    </p>
  </div>
</section>
